[Unit]
Description=Inventory Chatbot public gunicorn service
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/inventory-chatbot
ExecStart=/home/ubuntu/chatbot-env/bin/gunicorn \
  --workers 3 \
  --timeout 120 \
  --bind 0.0.0.0:5000 \
  app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
